# Example terraform.tfvars file
# Copy this file to terraform.tfvars and customize the values

resource_group_name = "rg-appgw-demo"
location            = "eastus"

vnet_name          = "vnet-appgw"
vnet_address_space = ["10.0.0.0/16"]

appgw_subnet_name           = "snet-appgw"
appgw_subnet_address_prefix = ["10.0.1.0/24"]

backend_subnet_name           = "snet-backend"
backend_subnet_address_prefix = ["10.0.2.0/24"]

public_ip_name = "pip-appgw"
appgw_name     = "appgw-demo"

# Options: Standard_Small, Standard_Medium, Standard_Large, Standard_v2, WAF_Medium, WAF_Large, WAF_v2
appgw_sku_name = "Standard_v2"

# Options: Standard, Standard_v2, WAF, WAF_v2
appgw_sku_tier = "Standard_v2"

# Instance count (1-125)
appgw_capacity = 2

# Key Vault Configuration for SSL Certificate
# Uncomment and configure these to enable HTTPS with Key Vault certificate
# key_vault_name                  = "kv-mykeyvault"
# key_vault_resource_group_name   = "rg-keyvault"
# key_vault_certificate_name      = "mycertificate"

tags = {
  Environment = "Demo"
  ManagedBy   = "Terraform"
  Purpose     = "Application Gateway Demo"
}
